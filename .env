# --- Submissions Database (used by web server + verification worker) ---
DATABASE_URL=postgresql://extsearch:a@localhost:5432/extsearch_dev

# --- Authentication Database (used by auth server) ---
AUTH_DATABASE_URL=postgresql://extsearch:a@localhost:5432/extsearch_auth

# --- Auth Server location (used by web server to delegate login/register) ---
# Leave empty to fall back to direct DB access (single-process dev mode)
AUTH_SERVER_URL=http://localhost:5001

# --- JWT (shared across all services) ---
JWT_SECRET=change-this-to-a-real-secret
JWT_EXPIRY_SECONDS=86400

# --- Flask ---
FLASK_SECRET_KEY=dev-secret-change-in-production
FLASK_ENV=development
FLASK_DEBUG=1
